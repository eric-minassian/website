{
  "plugins": ["typescript", "unicorn", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "import/no-unassigned-import": "off",
    "unicorn/require-module-specifiers": "off"
  },
  "ignorePatterns": ["dist/**", ".astro/**"]
}
