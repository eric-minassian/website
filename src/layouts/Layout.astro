---
import ThemeToggle from "../components/ThemeToggle.astro";
import { GA_ID, getThemeScript } from "../scripts/theme";
import "../styles/globals.css";

// Import font files with ?url to get hashed URLs for preloading
import latinNormal from "@fontsource-variable/newsreader/files/newsreader-latin-wght-normal.woff2?url";
import jetbrainsMonoLatin from "@fontsource-variable/jetbrains-mono/files/jetbrains-mono-latin-wght-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
  type?: "website" | "article";
  noindex?: boolean;
  wide?: boolean;
}

const {
  title = "Eric Minassian",
  description = "Software engineer and tech lead at Amazon, working on Leo. Previously led payments software at Walmart. CS + Business from UC Irvine, summa cum laude.",
  type = "website",
  noindex = false,
  wide = false,
} = Astro.props;

const siteUrl = "https://www.ericminassian.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = `${siteUrl}/og-image.png`;
const gaId = GA_ID;
// JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: "Eric Minassian",
      description,
      publisher: { "@id": `${siteUrl}/#person` },
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      name: "Eric Minassian",
      givenName: "Eric",
      familyName: "Minassian",
      url: siteUrl,
      image: ogImage,
      description,
      jobTitle: "Software Engineer & Tech Lead",
      worksFor: {
        "@type": "Organization",
        name: "Amazon",
        url: "https://amazon.com",
      },
      alumniOf: {
        "@type": "CollegeOrUniversity",
        name: "University of California, Irvine",
        url: "https://uci.edu",
      },
      knowsAbout: [
        "Software Engineering",
        "Payments Systems",
        "Distributed Systems",
      ],
      sameAs: [
        "https://github.com/eric-minassian",
        "https://linkedin.com/in/minassian-eric",
      ],
    },
    {
      "@type": "ProfilePage",
      "@id": `${siteUrl}/#profilepage`,
      url: siteUrl,
      name: "Eric Minassian",
      mainEntity: { "@id": `${siteUrl}/#person` },
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={latinNormal}
      crossorigin="anonymous"
    />
    {
      wide && (
        <link
          rel="preload"
          as="font"
          type="font/woff2"
          href={jetbrainsMonoLatin}
          crossorigin="anonymous"
        />
      )
    }
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="48x32x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Eric Minassian" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <link rel="me" href="https://github.com/eric-minassian" />
    <link rel="me" href="https://linkedin.com/in/minassian-eric" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Eric Minassian" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Eric Minassian - Software Engineer & Tech Lead" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Eric Minassian - Software Engineer & Tech Lead" />

    <!-- Theme -->
    <meta
      name="theme-color"
      content="#f8f5ed"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#171717"
      media="(prefers-color-scheme: dark)"
    />

    <!-- Google Analytics -->
    <script is:inline define:vars={{ gaId }}>
      function queueGtag() {
        window.dataLayer.push(arguments);
      }

      (() => {
        const measurementId = gaId;
        const isProduction = window.location.hostname === "www.ericminassian.com";
        const isBot = navigator.webdriver === true;
        if (!isProduction || isBot) return;

        window.dataLayer = window.dataLayer || [];
        window.gtag = window.gtag || queueGtag;

        let analyticsLoaded = false;

        const loadAnalytics = () => {
          if (analyticsLoaded) return;
          analyticsLoaded = true;

          const script = document.createElement("script");
          script.async = true;
          script.src = `https://www.googletagmanager.com/gtag/js?id=${measurementId}`;
          document.head.append(script);

          window.gtag("js", new Date());
          window.gtag("config", measurementId, { send_page_view: false });
          window.gtag("event", "page_view", {
            page_title: document.title,
            page_location: window.location.href,
          });
        };

        const scheduleAnalyticsLoad = () => {
          if ("requestIdleCallback" in window) {
            window.requestIdleCallback(loadAnalytics, { timeout: 3_000 });
            return;
          }

          window.setTimeout(loadAnalytics, 2_000);
        };

        const loadOnInteraction = () => {
          loadAnalytics();
          window.removeEventListener("pointerdown", loadOnInteraction);
          window.removeEventListener("keydown", loadOnInteraction);
        };

        window.addEventListener("load", scheduleAnalyticsLoad, { once: true });
        window.addEventListener("pointerdown", loadOnInteraction, { once: true, passive: true });
        window.addEventListener("keydown", loadOnInteraction, { once: true });

        document.addEventListener("click", (event) => {
          if (!(event.target instanceof Element)) return;

          const link = event.target.closest("a[href]");
          if (!link) return;

          const href = link.getAttribute("href");
          if (!href) return;

          const isExternal = href.startsWith("http") || href.startsWith("mailto:");
          if (!isExternal) return;

          window.gtag("event", "click", {
            event_category: href.startsWith("mailto:") ? "email" : "outbound",
            event_label: link.textContent.trim(),
            link_url: href,
          });
        });

        document.addEventListener("click", (event) => {
          if (!(event.target instanceof Element)) return;
          if (!event.target.closest("[data-theme-toggle]")) return;

          const themes = ["system", "dark", "light"];
          const current = localStorage.getItem("theme") || "system";
          const next = themes[(themes.indexOf(current) + 1) % themes.length];

          window.gtag("event", "theme_toggle", {
            event_category: "engagement",
            event_label: next,
          });
        });
      })();
    </script>

    <!-- JSON-LD -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Prevent FOUC: Apply dark class before render -->
    <script is:inline set:html={getThemeScript()}></script>
    <!-- Theme toggle logic -->
    <script>
      import { initTheme } from "../scripts/theme";
      initTheme();
    </script>
  </head>

  <body class:list={["mx-auto px-8 py-16", wide ? "max-w-[900px]" : "max-w-[650px]"]}>
    <main class="w-full mt-0 md:mt-16">
      <slot />
    </main>
    <footer class="mt-16 flex justify-center">
      <ThemeToggle />
    </footer>
  </body>
</html>
